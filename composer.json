{
    "name": "psc-acme/toolkit-invoice",
    "description": "Package toolkit-invoice for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ToolkitInvoice\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "symfony/cache": "^7.0",
        "doctrine/collections": "^2.0",
        "symfony/uid": "^7.0",
        "league/csv": "^9.0",
        "symfony/finder": "^7.0",
        "psc-acme/handler-billing": "^1.0"
    },
    "require-dev": {
        "symfony/phpunit-bridge": "^7.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}